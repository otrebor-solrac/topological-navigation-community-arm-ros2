    \hspace{1cm} {\Large \color{PPTSteel} \textbf{Infraestructura en ROS2 y Docker}} \par
    \vspace{0.4cm}
    \begin{columns}
        \column{0.6\textwidth}
        \begin{itemize}
            \item \textbf{Entorno de Trabajo:} Despliegue de la infraestructura mediante contenedores Docker para reproducibilidad del sistema \parencite{macenski2022robot}.
            \item \textbf{Integración del Hardware:} Importación del modelo físico (URDF y mallas) al ecosistema ROS2.
            \item \textbf{Visualización (RViz2):} Interfaz lista para recibir tópicos (\texttt{joint\_states}) y validar geométricamente las trayectorias \parencite{rviz2_software}.
        \end{itemize}
        
        \column{0.4\textwidth}
        \begin{center}
            \includegraphics[width=0.9\textwidth]{figuras/Robot-Arm.png} \\
