% ---------------------------------------------------
\section{Contexto y planteamiento}
% Lámina 3: Contexto y motivación
{
\usebackgroundtemplate{\includegraphics[width=\paperwidth,height=\paperheight]{figuras/pptx_images/Information_1.jpg}}
\begin{frame}[t]
    \vspace{1.2cm}
    \hspace{1cm} {\Large \color{PPTSteel} \textbf{Contexto y motivación}} \par
    \vspace{0.4cm}
    \begin{itemize}
        \item \textbf{Crisis de talento en la Industria 4.0:} Apenas el 7\% de la fuerza laboral manufacturera posee capacidades digitales avanzadas \parencite{Solleiro2023}.
        \item \textbf{Brecha Educativa:} La enseñanza robótica se limita a simuladores comerciales de \textit{caja negra} (ej. MoveIt) que ocultan la matemática subyacente \parencite{macenski2022robot}.
        \item \textbf{Resiliencia Tecnológica (TESH):} Desarrollo del hardware \textit{Community Robot Arm} de bajo costo \parencite{Garcia_Simulacion_2025}.
        \item \textbf{Aporte UnADM:} Dotar de rigor analítico al proyecto para transformar a los estudiantes en desarrolladores de tecnología \parencite{Zazueta_Educacion40_2023}.
    \end{itemize}
\end{frame}
}

% ---------------------------------------------------
% Lámina 4: Planteamiento del problema
{
\usebackgroundtemplate{\includegraphics[width=\paperwidth,height=\paperheight]{figuras/pptx_images/Information_1.jpg}}
\begin{frame}[t]
    \vspace{1.2cm}
    \hspace{1cm} {\Large \color{PPTSteel} \textbf{Planteamiento del problema}} \par
    \vspace{0.4cm}
    \begin{block}{La abstracción del movimiento}
        El manipulador antropomórfico no se mueve en un plano infinito, sino en un \textbf{espacio de configuración con estructura toroidal ($T^n$)} \parencite{Munkres2000}. 
    \end{block}
    \vspace{0.3cm}
    \textbf{Retos principales:}
    \begin{enumerate}
        \item Transformar esta geometría abstracta en un entorno de cálculo numérico \parencite{farber2008}.
        \item Contrastar dos filosofías de exploración geométrica: 
        \begin{itemize}
            \item \textbf{A*:} Discretización en retícula determinista \parencite{Hart1968}.
            \item \textbf{RRT:} Muestreo estocástico de árboles conexos \parencite{LaValle1998}.
        \end{itemize}
        \item Carencia de un entorno de \textit{software caja blanca} para experimentar la viabilidad topológica de las trayectorias.
    \end{enumerate}
\end{frame}
}

% ---------------------------------------------------
% Lámina 5: Pregunta de Investigación e Hipótesis
{
\usebackgroundtemplate{\includegraphics[width=\paperwidth,height=\paperheight]{figuras/pptx_images/Information_1.jpg}}
\begin{frame}[t]
    \vspace{1.2cm}
    \hspace{1cm} {\Large \color{PPTSteel} \textbf{Pregunta de investigación e hipótesis}} \par
    \vspace{0.4cm}
    \textbf{Pregunta de investigación:} \\
    ¿De qué manera es posible modelar el espacio $T^n$ integrando recubrimientos por bolas abiertas y análisis diferencial para permitir el estudio comparativo de eficiencia entre A* y RRT?
    
    \vspace{0.5cm}
    \textbf{Hipótesis:}
    \begin{itemize}
        \item La formalización toroidal y las bolas abiertas permitirán una plataforma capaz de resolver la conectividad por caminos libre de obstáculos.
        \item \textbf{A*:} Garantizará el hallazgo de la trayectoria óptima (con métricas $L_1, L_2$) ideal para análisis de precisión.
        \item \textbf{RRT:} Ofrecerá completitud probabilística y eficiencia en geometrías donde la retícula determinista sufra explosión combinatoria.
    \end{itemize}
\end{frame}
}

% ---------------------------------------------------
% Lámina 6: Objetivos
{
\usebackgroundtemplate{\includegraphics[width=\paperwidth,height=\paperheight]{figuras/pptx_images/Information_1.jpg}}
\begin{frame}[t]
    \vspace{1.2cm}
    \hspace{1cm} {\Large \color{PPTSteel} \textbf{Objetivos del proyecto}} \par
    \vspace{0.4cm}
    \textbf{Objetivo General:} \\
    Desarrollar una plataforma de planificación topológica para comparar algoritmos y fortalecer la enseñanza matemática en ingeniería.
    
    \vspace{0.3cm}
    \textbf{Objetivos Específicos:}
    \begin{enumerate}
        \item \textbf{Modelar} analíticamente el subespacio libre $\mathcal{C}_{free}$ mediante la teoría de recubrimientos por bolas abiertas \parencite{coumar2025foam}.
        \item \textbf{Implementar} A* y RRT en un paquete propio de ROS2, usando análisis diferencial para evadir inestabilidades topológicas \parencite{Mosquera2017}.
        \item \textbf{Evaluar} convergencia utilizando métricas \textit{wrap-around} y visualizar en RViz2 \parencite{lynch2017modern}.
    \end{enumerate}
\end{frame}
}

% ---------------------------------------------------
\section{Avances teóricos}
% Lámina 7: Avances - Robótica Topológica y el Toro
{
\usebackgroundtemplate{\includegraphics[width=\paperwidth,height=\paperheight]{figuras/pptx_images/Information_1.jpg}}
\begin{frame}[t]
    \vspace{1.2cm}
    \hspace{1cm} {\Large \color{PPTSteel} \textbf{Robótica topológica y el toro $T^n$}} \par
    \vspace{0.4cm}
    \begin{columns}
        \column{0.5\textwidth}
        \begin{itemize}
            \item El estado de las $n$ articulaciones reside en una variedad compacta: el producto cartesiano $S^1 \times \dots \times S^1 = T^n$ \parencite{farber2008}.
            \item \textbf{Identificación de bordes:} A través de la topología cociente, el ángulo $359^\circ$ es continuo con $1^\circ$ \parencite{antonyan2016topologia}.
            \item \textbf{Métricas adaptadas:} Implementación de distancias \textit{wrap-around} para reflejar las geodésicas reales \parencite{lynch2017modern}.
        \end{itemize}
        
        \column{0.5\textwidth}
        \begin{center}
            \input{figuras/toro.tex}
            
            \vspace{0.3cm} % Ajustado para mover el título hacia abajo
            \textit{\footnotesize Representación tridimensional de la variedad $T^2$ ($S^1 \times S^1$).}
        \end{center}
    \end{columns}
\end{frame}
}

% ---------------------------------------------------
% Lámina 8: Avances - Geometría y Recubrimientos
{
\usebackgroundtemplate{\includegraphics[width=\paperwidth,height=\paperheight]{figuras/pptx_images/Information_1.jpg}}
\begin{frame}[t]
    \vspace{1.2cm}
    \hspace{1cm} {\Large \color{PPTSteel} \textbf{Avance Teórico: Geometría y Recubrimientos}} \par
    \vspace{0.4cm}
    \begin{columns}
        \column{0.5\textwidth}
        \begin{itemize}
            \item Transición de obstáculos en $\mathbb{R}^3$ a \enquote{agujeros} en el espacio de configuración ($\mathcal{C}_{obs}$) \parencite{oniani2019topology}.
            \item \textbf{Aproximación esférica:} Se reemplazan las cajas AABB de la ingeniería clásica por \textbf{uniones finitas de bolas abiertas} \parencite{coumar2025foam}.
            \item \textbf{Ventaja:} Optimiza el costo de consultas de distancia $L_2$ y garantiza una aproximación estricta y topológicamente consistente de $\mathcal{C}_{free}$ \parencite{coumar2025foam}.
        \end{itemize}
        
        \column{0.5\textwidth}
        \begin{center}
            \input{figuras/bolas_vs_aabb.tex}
            
            \vspace{0.4cm}
            \textit{\footnotesize Comparativa de aproximación geométrica para detección de colisiones.}
        \end{center}
    \end{columns}
\end{frame}
}
% ---------------------------------------------------
% Lámina 9: Avance Teórico - Algoritmos y Discretización
{
\usebackgroundtemplate{\includegraphics[width=\paperwidth,height=\paperheight]{figuras/pptx_images/Information_1.jpg}}
\begin{frame}[t]
    \vspace{1.2cm}
    \hspace{1cm} {\Large \color{PPTSteel} \textbf{Algoritmos y discretización}} \par
    \vspace{0.4cm}
    \begin{itemize}
        \item \textbf{Búsqueda Determinista (A*):} La métrica Manhattan ($L_1$) guía mejor la heurística en la retícula toroidal frente a la Euclidiana ($L_2$) \parencite{lavalle2006planning}.
        \item \textbf{Búsqueda Estocástica (RRT):} El muestreo aleatorio uniforme elude la \enquote{maldición de la dimensionalidad} y los mínimos locales \parencite{choset2005principles}.
        \item \textbf{Singularidades:} El \enquote{Gimbal-lock} o pérdida de rango del Jacobiano se aborda como una inestabilidad topológica (Teorema de Farber) \parencite{Mosquera2017}.
    \end{itemize}
\end{frame}
}

